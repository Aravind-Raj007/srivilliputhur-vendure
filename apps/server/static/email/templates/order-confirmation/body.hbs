{{> header title="Order Confirmation" }}

<mj-section background-color="#ffffff">
    <mj-column width="100%">
        <mj-text font-size="20px" font-weight="bold" color="#333">
            Order Confirmed: #{{ order.code }}
        </mj-text>
        <mj-text font-size="16px" line-height="1.5" color="#666">
            Hello {{ order.customer.firstName }}, thank you for shopping with SugaBramar. We've received your order and are preparing it for delivery.
        </mj-text>
        <mj-divider border-width="1px" border-color="#eee" />
    </mj-column>
</mj-section>

<mj-section background-color="#ffffff" padding-top="0">
    <mj-column>
        <mj-text font-size="16px">
            <strong>Expected Delivery:</strong> 3-5 Business Days
        </mj-text>
        <mj-text font-size="14px" color="#666">
            <strong>Shipping to:</strong><br/>
            {{ order.shippingAddress.fullName }}<br/>
            {{ order.shippingAddress.streetLine1 }}, {{ order.shippingAddress.city }}
        </mj-text>
    </mj-column>
</mj-section>

<mj-section background-color="#ffffff" padding-top="0">
    <mj-column>
        <mj-text font-weight="bold">Items Ordered:</mj-text>
        <mj-table>
            {{#each order.lines }}
            <tr>
                <td style="padding: 5px 0;">{{ quantity }} x {{ productVariant.name }}</td>
                <td align="right">{{ formatMoney linePriceWithTax }}</td>
            </tr>
            {{/each}}
            <tr style="font-weight: bold; font-size: 16px; border-top: 1px solid #eee;">
                <td style="padding-top: 10px;">Total Amount Paid</td>
                <td align="right" style="padding-top: 10px;">{{ formatMoney order.totalWithTax }}</td>
            </tr>
        </mj-table>
    </mj-column>
</mj-section>

<mj-section background-color="#f9f9f9">
    <mj-column>
        <mj-text align="center" font-size="12px" color="#999">
            SugaBramar - Handmade Leaf & Flower Designs<br/>
            Contact: info@sugabramar.com
        </mj-text>
    </mj-column>
</mj-section>

{{> footer }}
